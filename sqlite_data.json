te_template": "", "status": "published", "is_active": true, "created_at": "2026-04-15T08:50:25.198Z", "updated_at": "2026-04-15T08:50:25.199Z", "published_at": "2026-04-15T08:50:25.198Z"}}, {"model": "lms.course", "pk": 4, "fields": {"department": 1, "title": "Structural Design Fundamentals", "slug": "structural-design-fundamentals", "code": "CEI-805C9C", "description": "Structural Design Fundamentals for Department of Civil Engineering and Infrastructure.", "learning_objectives": "Practical industry-aligned competencies", "prerequisites": "Basic technical literacy", "duration": "6 months", "estimated_hours": 40, "difficulty": "beginner", "price": "0.00", "currency": "USD", "assignment_weight": 70, "project_weight": 30, "require_quiz_pass": true, "quiz_pass_score": 70, "thumbnail": "", "promo_video_url": "", "google_classroom_id": null, "certificate_template": "", "status": "published", "is_active": true, "created_at": "2026-04-15T08:50:25.216Z", "updated_at": "2026-04-15T08:50:25.216Z", "published_at": "2026-04-15T08:50:25.215Z"}}, {"model": "lms.course", "pk": 5, "fields": {"department": 1, "title": "Materials Testing Laboratory Practice", "slug": "materials-testing-laboratory-practice", "code": "CEI-B877F9", "description": "Materials Testing Laboratory Practice for Department of Civil Engineering and Infrastructure.", "learning_objectives": "Practical industry-aligned competencies", "prerequisites": "Basic technical literacy", "duration": "4 - 8 weeks", "estimated_hours": 40, "difficulty": "beginner", "price": "0.00", "currency": "USD", "assignment_weight": 70, "project_weight": 30, "require_quiz_pass": true, "quiz_pass_score": 70, "thumbnail": "", "promo_video_url": "", "google_classroom_id": null, "certificate_template": "", "status": "published", "is_active": true, "created_at": "2026-04-15T08:50:25.229Z", "updated_at": "2026-04-15T08:50:25.229Z", "published_at": "2026-04-15T08:50:25.228Z"}}, {"model": "lms.course", "pk": 6, "fields": {"department": 1, "title": "Environmental Compliance in Construction", "slug": "environmental-compliance-in-construction", "code": "CEI-D8B15E", "description": "Environmental Compliance in Construction for Department of Civil Engineering and Infrastructure.", "learning_objectives": "Practical industry-aligned competencies", "prerequisites": "Basic technical literacy", "duration": "2 weeks", "estimated_hours": 40, "difficulty": "beginner", "price": "0.00", "currency": "USD", "assignment_weight": 70, "project_weight": 30, "require_quiz_pass": true, "quiz_pass_score": 70, "thumbnail": "", "promo_video_url": "", "google_classroom_id": null, "certificate_template": "", "status": "published", "is_active": true, "created_at": "2026-04-15T08:50:25.242Z", "updated_at": "2026-04-15T08:50:25.242Z", "published_at": "2026-04-15T08:50:25.241Z"}}, {"model": "lms.chapter", "pk": 1, "fields": {"course": 1, "title": "Introduction to Engineering Surveying", "order": 1, "chapter_type": "lesson", "document_file": "", "video_url": "https://youtu.be/ZH-tHW9K5jI?si=oUiSCsdB0MqHrtG_", "content": "<h2>Introduction to Engineering Surveying</h2>\r\n<p>Welcome to Engineering Surveying. This chapter introduces core concepts and why surveying is essential in civil engineering projects.</p>\r\n<h3>Learning Objectives</h3>\r\n<ul>\r\n    <li>Define engineering surveying and its purpose</li>\r\n    <li>Identify major survey types and use cases</li>\r\n    <li>Understand key terms used in fieldwork</li>\r\n</ul>\r\n<h3>Key Concepts</h3>\r\n<ul>\r\n    <li>Benchmark, leveling, traverse, contour line</li>\r\n    <li>Azimuth and bearing basics</li>\r\n    <li>Surveying as foundation for roads, buildings, drainage, and bridges</li>\r\n</ul>\r\n<h3>Summary</h3>\r\n<p>Surveying is the first and most critical step in construction planning and execution.</p>\r\n", "content_html": "", "estimated_minutes": 45, "template_doc_id": "", "is_free_preview": false, "requires_previous_quiz_pass": true, "created_at": "2026-04-15T10:32:48.407Z", "updated_at": "2026-04-15T12:47:31.779Z"}}, {"model": "lms.chapter", "pk": 2, "fields": {"course": 1, "title": "Surveying Instruments and Equipment", "order": 2, "chapter_type": "lesson", "document_file": "", "video_url": "https://www.youtube.com/embed/3gUfBcLrMlQ", "content": "\n<h2>Surveying Instruments and Equipment</h2>\n<p>This chapter covers practical field equipment used by surveyors.</p>\n<h3>Essential Instruments</h3>\n<ul>\n    <li>Total Station (angles + EDM + coordinate calculations)</li>\n    <li>GPS/GNSS Receiver (RTK and static workflows)</li>\n    <li>Automatic Level (elevation measurement)</li>\n    <li>Theodolite (precise angle measurement)</li>\n</ul>\n<h3>Care and Maintenance</h3>\n<ul>\n    <li>Store in protective cases</li>\n    <li>Handle optics with lens paper only</li>\n    <li>Perform regular calibration checks</li>\n</ul>\n", "content_html": "", "estimated_minutes": 60, "template_doc_id": "", "is_free_preview": false, "requires_previous_quiz_pass": true, "created_at": "2026-04-15T10:32:48.415Z", "updated_at": "2026-04-15T10:32:48.415Z"}}, {"model": "lms.chapter", "pk": 3, "fields": {"course": 1, "title": "Leveling and Height Measurement", "order": 3, "chapter_type": "lesson", "document_file": "", "video_url": "https://www.youtube.com/embed/4K5dZM4n_v4", "content": "\n<h2>Leveling and Height Measurement</h2>\n<p>Learn to measure elevation differences accurately for engineering design and construction.</p>\n<h3>Core Formulas</h3>\n<p><strong>HI = BM Elevation + Backsight</strong></p>\n<p><strong>RL = HI - Foresight</strong></p>\n<h3>Leveling Types</h3>\n<ul>\n    <li>Differential leveling</li>\n    <li>Profile leveling</li>\n    <li>Cross-section leveling</li>\n    <li>Reciprocal leveling</li>\n</ul>\n<h3>Practical Focus</h3>\n<p>Field setup, reading sequence, calculations, and closure/error checks.</p>\n", "content_html": "", "estimated_minutes": 50, "template_doc_id": "", "is_free_preview": false, "requires_previous_quiz_pass": true, "created_at": "2026-04-15T10:32:48.422Z", "updated_at": "2026-04-15T10:32:48.422Z"}}, {"model": "lms.chapter", "pk": 4, "fields": {"course": 1, "title": "Distance Measurement and Traversing", "order": 4, "chapter_type": "lesson", "document_file": "", "video_url": "", "content": "\n<h2>Distance Measurement and Traversing</h2>\n<p>This chapter introduces traversing workflows, coordinate computation, and error adjustment.</p>\n<h3>Distance Methods</h3>\n<ul>\n    <li>Tape measurement</li>\n    <li>EDM/Total Station</li>\n    <li>GPS/GNSS</li>\n</ul>\n<h3>Traverse Basics</h3>\n<ul>\n    <li>Closed and open traverse types</li>\n    <li>Latitude and departure</li>\n    <li>Coordinate calculations (Easting/Northing)</li>\n    <li>Bowditch adjustment rule</li>\n</ul>\n", "content_html": "", "estimated_minutes": 55, "template_doc_id": "", "is_free_preview": false, "requires_previous_quiz_pass": true, "created_at": "2026-04-15T10:32:48.429Z", "updated_at": "2026-04-15T10:32:48.429Z"}}, {"model": "lms.chapter", "pk": 5, "fields": {"course": 1, "title": "Engineering Surveying Quiz", "order": 5, "chapter_type": "quiz", "document_file": "", "video_url": "", "content": "Test your knowledge of surveying fundamentals.", "content_html": "", "estimated_minutes": 30, "template_doc_id": "", "is_free_preview": false, "requires_previous_quiz_pass": true, "created_at": "2026-04-15T10:32:48.437Z", "updated_at": "2026-04-15T10:32:48.437Z"}}, {"model": "lms.quiz", "pk": 1, "fields": {"chapter": 5, "title": "Engineering Surveying Fundamentals Quiz", "description": "Assessment on fundamentals of surveying concepts and calculations.", "pass_score": 70, "time_limit_minutes": 30, "attempts_allowed": 2, "shuffle_questions": true, "show_answers_after_submit": true}}, {"model": "lms.question", "pk": 1, "fields": {"quiz": 1, "text": "What is the most commonly used instrument for modern surveying?", "question_type": "mcq", "options": ["Theodolite", "Automatic Level", "Total Station", "GPS"], "correct_answer": "Total Station", "explanation": "", "points": 10, "order": 1}}, {"model": "lms.question", "pk": 2, "fields": {"quiz": 1, "text": "A backsight reading is taken on an unknown point.", "question_type": "tf", "options": ["True", "False"], "correct_answer": "False", "explanation": "", "points": 10, "order": 2}}, {"model": "lms.question", "pk": 3, "fields": {"quiz": 1, "text": "What does HI stand for in leveling calculations?", "question_type": "mcq", "options": ["Horizontal Index", "Height of Instrument", "Height Indicator", "Horizontal Indicator"], "correct_answer": "Height of Instrument", "explanation": "", "points": 10, "order": 3}}, {"model": "lms.question", "pk": 4, "fields": {"quiz": 1, "text": "Calculate the Reduced Level if HI = 105.500 m and FS = 2.350 m.", "question_type": "short", "options": [], "correct_answer": "103.150 m", "explanation": "", "points": 10, "order": 4}}, {"model": "lms.question", "pk": 5, "fields": {"quiz": 1, "text": "GPS provides more accurate distance measurements than a total station for short distances.", "question_type": "tf", "options": ["True", "False"], "correct_answer": "False", "explanation": "", "points": 10, "order": 5}}, {"model": "lms.question", "pk": 6, "fields": {"quiz": 1, "text": "Which type of survey is used to map terrain features?", "question_type": "mcq", "options": ["Boundary Survey", "Topographic Survey", "Construction Survey", "Hydrographic Survey"], "correct_answer": "Topographic Survey", "explanation": "", "points": 10, "order": 6}}, {"model": "lms.question", "pk": 7, "fields": {"quiz": 1, "text": "What is the formula for calculating Height of Instrument (HI)?", "question_type": "short", "options": [], "correct_answer": "HI = BM Elevation + Backsight Reading", "explanation": "", "points": 10, "order": 7}}, {"model": "lms.question", "pk": 8, "fields": {"quiz": 1, "text": "In a closed traverse, the sum of latitudes should equal:", "question_type": "mcq", "options": ["0", "360", "180", "Perimeter"], "correct_answ